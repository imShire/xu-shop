# 应用
APP_ENV=dev
APP_PORT=8080
APP_SECRET_KEY=
INSTANCE_ID=0

# 数据库
DB_DSN=postgres://shop:shop@localhost:5432/shop?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_DB=0
ASYNQ_REDIS_ADDR=localhost:6379
ASYNQ_REDIS_DB=1

# JWT
JWT_SECRET=
JWT_USER_TTL_HOURS=720
JWT_ADMIN_TTL_HOURS=8

# OSS (dev 用 minio)
OSS_ENDPOINT=http://localhost:9000
OSS_REGION=cn-hangzhou
OSS_BUCKET=xu-shop-dev
OSS_AK=minioadmin
OSS_SK=minioadmin
OSS_CDN_DOMAIN=http://localhost:9000/xu-shop-dev

# 微信支付（敏感项由后台「系统参数」维护）
WXPAY_ENV=sandbox

# 日志
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=
PROM_METRICS_ENABLED=true
